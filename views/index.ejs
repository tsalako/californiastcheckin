<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>California St. Check-in</title>
    <link rel="stylesheet" href="/style.css" />
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
      window.AUTO_CHECK_IN_AUTHORIZED = <%= autoCheckInAuthorized ? 'true' : 'false' %>;
      window.AUTO_PASS_CREATION = <%= autoPassCreation ? 'true' : 'false' %>;
      window.AUTO_VISIT_RECORDING = <%= autoVisitRecording ? 'true' : 'false' %>;
      window.AUTO_CLICK_CREATION_LINKS = <%= autoClickCreationLinks ? 'true' : 'false' %>;
      window.AUTO_CLICK_RECORDING_LINKS = <%= autoClickRecordingLinks ? 'true' : 'false' %>;
      window.CLOSE_AFTER_WALLET_REDIRECT = <%= closeAfterWalletRedirect ? 'true' : 'false' %>;
      window.UPDATE_APPLE_WALLET = <%= udpateAppleWallet ? 'true' : 'false' %>;

      if (window.AUTO_CHECK_IN_AUTHORIZED) {
        // Strip the NFC token from the visible URL after this render is authorized.
        // The current auto flow can continue, but refresh/history reopens request `/`
        // without the token and therefore fall back to the manual check-in path.
        const initialUrl = new URL(window.location.href);
        if (
          initialUrl.searchParams.has("checkin") ||
          initialUrl.searchParams.has("autoToken")
        ) {
          initialUrl.searchParams.delete("checkin");
          initialUrl.searchParams.delete("autoToken");
          window.history.replaceState(
            null,
            "",
            initialUrl.pathname + initialUrl.search + initialUrl.hash
          );
        }
      }
    </script>
  </head>
  <body>
    <div class="container">
      <h2 class="form-title">California St. Check-in</h2>

      <div class="form-content">
        <!-- Identity -->
        <div class="stack-slot">
          <div id="signinWrapper" class="slot-item hidden">
            <div
              id="g_id_onload"
              data-client_id="<%= googleClientId %>"
              data-callback="onSignIn"
              data-auto_prompt="false"
              data-auto_select="true"
            ></div>
            <div
              class="g_id_signin"
              data-type="standard"
              data-size="large"
              data-theme="outline"
              data-text="sign_in_with"
              data-shape="rectangular"
              data-logo_alignment="left"
            ></div>
            <button id="altSignInToggle" class="text-link">
              Sign in without Google
            </button>
          </div>

          <div id="manualSignInWrapper" class="slot-item hidden">
            <div class="manual-signin-wrapper">
              <form id="manualSignInForm" class="manual-signin-form">
                <div class="form-row">
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    placeholder="First Name"
                    required
                  />
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    placeholder="Last Name"
                    required
                  />
                </div>
                <input
                  type="email"
                  id="emailManual"
                  name="email"
                  placeholder="Email"
                  required
                />
                <button type="submit" class="button" id="manualSubmit">
                  Continue
                </button>
              </form>
              <button id="backToGoogle" class="text-link">
                Back to Google Sign-in
              </button>
            </div>
          </div>

          <div id="signedInWrapper" class="slot-item hidden">
            <p id="signedInAs" class="signed-in-as"></p>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="stack-slot">
          <div id="createWrapper" class="slot-item hidden">
            <button id="createPassSubmit" class="button">Create Pass</button>
          </div>
          <div id="recordWrapper" class="slot-item hidden">
            <button id="recordVisit" class="button">Record Visit</button>
          </div>
        </div>

        <!-- Feedback + Wallet -->
        <div class="stack-slot">
          <div class="slot-item visible">
            <div class="feedback-wallet-wrapper">
              <div id="feedback" class="feedback" aria-live="polite"></div>
              <div id="button" class="wallet-button-wrapper"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      let userEmail = "",
        fullName = "";
      let isRecording = false;
      const isApple = /iPhone|iPad|iPod/i.test(navigator.userAgent);
      // const isApple = true;
      const platform = isApple ? "apple" : "google";

      const feedbackEl = document.getElementById("feedback");
      const recordVisit = document.getElementById("recordVisit");
      const createPassSubmit = document.getElementById("createPassSubmit");

      function tryCloseAppAfterWalletRedirect() {
        if (!window.CLOSE_AFTER_WALLET_REDIRECT) return;

        feedbackEl.textContent = "Pass sent to Wallet. You can close this tab.";
        feedbackEl.classList.add("show");

        setTimeout(() => {
          window.open("", "_self");
          window.close();
        }, 1200);
      }

      function autoOpenWalletLink(anchor) {
        anchor.click();
        tryCloseAppAfterWalletRedirect();
      }

      // Will be set by /hasPass or /record-visit JSON
      window.__USER_ID__ = window.__USER_ID__ || null;

      const IDENTITY_MAX_AGE_SECONDS = 60 * 60 * 24 * 366;

      function getCookieMap() {
        return document.cookie.split("; ").reduce((acc, c) => {
          if (!c) return acc;
          const separatorIndex = c.indexOf("=");
          const key = separatorIndex >= 0 ? c.slice(0, separatorIndex) : c;
          const value = separatorIndex >= 0 ? c.slice(separatorIndex + 1) : "";
          acc[key] = decodeURIComponent(value);
          return acc;
        }, {});
      }

      function getCookieAttributes() {
        const attrs = [`max-age=${IDENTITY_MAX_AGE_SECONDS}`, "path=/", "SameSite=Lax"];
        if (window.location.protocol === "https:") attrs.push("Secure");
        return attrs.join("; ");
      }

      function persistSignedInState(email, name) {
        const cookieAttributes = getCookieAttributes();
        document.cookie = `userEmail=${encodeURIComponent(email)}; ${cookieAttributes}`;
        document.cookie = `name=${encodeURIComponent(name)}; ${cookieAttributes}`;
      }

      function getStoredIdentity() {
        const cookies = getCookieMap();
        if (!cookies.userEmail) return null;
        return { email: cookies.userEmail, name: cookies.name || cookies.userEmail };
      }

      async function getServerIdentity() {
        const res = await fetch("/auth/session");
        if (!res.ok) return null;
        const data = await res.json().catch(() => ({}));
        return data.identity || null;
      }

      async function saveManualServerIdentity(email, name) {
        const res = await fetch("/auth/manual", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: `name=${encodeURIComponent(name)}&email=${encodeURIComponent(email)}`,
        });
        if (!res.ok) return null;
        const data = await res.json().catch(() => ({}));
        return data.identity || null;
      }

      async function saveGoogleServerIdentity(credential) {
        const res = await fetch("/auth/google", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ credential }),
        });
        if (!res.ok) return null;
        const data = await res.json().catch(() => ({}));
        return data.identity || null;
      }

      function decodeCredentialPayload(credential) {
        return JSON.parse(atob(credential.split(".")[1]));
      }

      async function handleSignedInState(email, name, options = {}) {
        userEmail = email;
        fullName = name || email;

        persistSignedInState(userEmail, fullName);
        if (!options.skipServerPersist) {
          try {
            await saveManualServerIdentity(userEmail, fullName);
          } catch (err) {
            console.warn("Could not persist sign-in identity to the server session.", err);
          }
        }
        hasPassCheck(userEmail, fullName);
      }

      function hasPassCheck(email, name) {
        document.getElementById("signinWrapper").classList.replace("visible", "hidden");
        document.getElementById("signedInWrapper").classList.replace("hidden", "visible");
        document.getElementById("signedInAs").textContent = name;

        fetch(`/hasPass?email=${encodeURIComponent(email)}&platform=${platform}`)
          .then((res) => res.json())
          .then(({ exists }) => {
            // window.__USER_ID__ = userId || window.__USER_ID__;
            if (exists) {
              document.getElementById("recordWrapper").classList.replace("hidden", "visible");
              if (window.AUTO_VISIT_RECORDING) recordVisit.click();
            } else {
              document.getElementById("createWrapper").classList.replace("hidden", "visible");
              if (window.AUTO_PASS_CREATION) createPassSubmit.click();
            }
          });
      }

      async function onSignIn(response) {
        try {
          const identity = await saveGoogleServerIdentity(response.credential);
          if (identity) {
            return handleSignedInState(identity.email, identity.name, { skipServerPersist: true });
          }
        } catch (err) {
          console.warn("Could not persist Google sign-in to the server session.", err);
        }

        const payload = decodeCredentialPayload(response.credential);
        handleSignedInState(payload.email, payload.name);
      }

      document.getElementById("altSignInToggle").addEventListener("click", () => {
        document.getElementById("signinWrapper").classList.replace("visible", "hidden");
        document.getElementById("manualSignInWrapper").classList.replace("hidden", "visible");
      });

      document.getElementById("backToGoogle").addEventListener("click", () => {
        document.getElementById("manualSignInWrapper").classList.replace("visible", "hidden");
        document.getElementById("signinWrapper").classList.replace("hidden", "visible");
      });

      document.getElementById("manualSignInForm").addEventListener("submit", async (e) => {
        e.preventDefault();
        const first = document.getElementById("firstName").value.trim();
        const last = document.getElementById("lastName").value.trim();
        const email = document.getElementById("emailManual").value.trim();
        if (!first || !last || !email) return;
        document.getElementById("manualSignInWrapper").classList.replace("visible", "hidden");
        const name = `${first} ${last}`;

        try {
          const identity = await saveManualServerIdentity(email, name);
          if (identity) {
            return handleSignedInState(identity.email, identity.name, { skipServerPersist: true });
          }
        } catch (err) {
          console.warn("Could not persist manual sign-in to the server session.", err);
        }

        handleSignedInState(email, name);
      });

      window.addEventListener("DOMContentLoaded", async () => {
        const signinWrapper = document.getElementById("signinWrapper");
        signinWrapper.classList.replace("hidden", "visible");
        if (!isApple) {
          document.getElementById("altSignInToggle").style.display = "none";
        }

        let identity = null;
        try {
          identity = await getServerIdentity();
        } catch (err) {
          console.warn("Could not read the server sign-in session.", err);
        }

        identity = identity || getStoredIdentity();
        if (!identity) return;

        // Refresh browser storage and the server cookie so returning users keep the full remembered window.
        handleSignedInState(identity.email, identity.name);
      });

      createPassSubmit.addEventListener("click", async () => {
        createPassSubmit.disabled = true;
        createPassSubmit.textContent = "Creating...";

        const container = document.getElementById("button");
        const email = userEmail;
        const name = fullName;

        const res = await fetch(`/create-pass`, {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: `name=${encodeURIComponent(name)}&email=${encodeURIComponent(email)}&platform=${platform}`,
        });

        if (res.ok) {
          const data = await res.json();
          // window.__USER_ID__ = data.userId || window.__USER_ID__;
          createPassSubmit.textContent = "Created";
          const a = document.createElement("a");
          a.href = platform === "apple" ? data.url : data.button;

          const img = new Image();
          img.src = platform === "apple" ? "apple-wallet-button.svg" : "google-wallet-button.png";
          img.alt = platform === "apple" ? "Save to Apple Wallet" : "Save to Google Wallet";
          img.style.height = "50px";
          img.style.width = "auto";

          img.onload = () => {
            a.appendChild(img);
            container.innerHTML = "";
            container.appendChild(a);
            container.classList.add("show");
            if (window.AUTO_CLICK_CREATION_LINKS) autoOpenWalletLink(a);
          };

          img.onerror = () => {
            a.textContent = platform === "apple" ? "Download Pass" : "Save to Wallet";
            container.innerHTML = "";
            container.appendChild(a);
            container.classList.add("show");
            if (window.AUTO_CLICK_CREATION_LINKS) autoOpenWalletLink(a);
          };
        } else {
          const data = await res.json().catch(() => ({}));
          feedbackEl.textContent = data.message || "⚠️ Failed to create pass.";
          feedbackEl.classList.add("show");
          createPassSubmit.textContent = "Create Pass";
          createPassSubmit.disabled = false;
        }
      });

      recordVisit.addEventListener("click", async () => {
        recordVisit.disabled = true;
        recordVisit.textContent = "Recording...";

        const email = userEmail;
        const name = fullName;

        const res = await fetch("/record-visit", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: `name=${encodeURIComponent(name)}&email=${encodeURIComponent(email)}&platform=${platform}`,
        });

        const data = await res.json().catch(() => ({}));
        if (res.ok) {
          recordVisit.textContent = "Recorded!";
  
          // Apple: show update (or push) if applicable
          if (platform === "apple") {
            if (window.UPDATE_APPLE_WALLET && data.hasRegisteredDevice) {
              try {
                await fetch(`/push-update?email=${encodeURIComponent(email)}`);
              } catch (err) {
                feedbackEl.textContent = err.message || "⚠️ Failed to record visit.";
                feedbackEl.classList.add("show");
                recordVisit.textContent = "Record Visit";
                recordVisit.disabled = false;
              }
            } else if (data.url) {
              const container = document.getElementById("button");
              const a = document.createElement("a");
              a.href = data.url;

              const img = new Image();
              img.src = "apple-wallet-button.svg";
              img.alt = "Update Apple Wallet";
              img.style.height = "50px";
              img.style.width = "auto";

              img.onload = () => {
                a.appendChild(img);
                container.innerHTML = "";
                container.appendChild(a);
                container.classList.add("show");
                if (window.AUTO_CLICK_RECORDING_LINKS) autoOpenWalletLink(a);
              };

              img.onerror = () => {
                console.warn("Failed to load Apple Wallet image.");
                a.textContent = "Download Pass";
                container.innerHTML = "";
                container.appendChild(a);
                container.classList.add("show");
                if (window.AUTO_CLICK_RECORDING_LINKS) autoOpenWalletLink(a);
              };
            }
          }
        } else {
          feedbackEl.textContent = data.message || "⚠️ Failed to record visit.";
          feedbackEl.classList.add("show");
          recordVisit.textContent = "Record Visit";
          recordVisit.disabled = false;
        }

        setTimeout(() => feedbackEl.classList.remove("show"), 3000);
      });
    </script>
  </body>
</html>
